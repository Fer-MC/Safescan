# Copia este archivo a .env y rellena los valores.
# NUNCA subas .env a git ni lo compartas.

# Clave de la API de Anthropic (obligatoria). Consíguela en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Modo debug (logs detallados). Déjalo en false en producción.
DEBUG=false
