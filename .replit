run = "cd backend && python3 -m uvicorn main:app --host 0.0.0.0 --port 8080"
modules = ["python-3.11"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"
